# WarWatch.World — Environment Variables
# Copy this file to .env.local and fill in real values

# Groq API — get yours free at console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# NewsAPI.org — get yours at newsapi.org
NEWSAPI_KEY=your_newsapi_key_here

# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://warwatch.world

# GitHub repo URL
NEXT_PUBLIC_GITHUB_URL=https://github.com/nitinchhabria89/WarWatch.World

# Google AdSense publisher ID (optional — ads will be hidden if not set)
NEXT_PUBLIC_ADSENSE_PUB_ID=pub-XXXXXXXXXXXXXXXX

# Optional: Vercel KV or Redis URL for caching (falls back to filesystem)
# KV_URL=
